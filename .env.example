# 高德开放平台 Web 服务 key (服务端用, 绝不暴露给前端)
# 申请: https://lbs.amap.com/dev/key/app
# 创建应用 → 添加 key → 服务平台选 "Web 服务"
# 配额: 个人免费 5k 次/天, 演示足够
AMAP_WEB_KEY=

# MiniMax 语音克隆 / TTS (服务端用, 绝不暴露给前端)
# 1) 在 MiniMax 平台创建 API Key
# 2) 用 /api/voice/minimax/clone 上传样本音频创建 voice_id
# 3) 把返回的 voiceId 填到 MINIMAX_VOICE_ID
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io
MINIMAX_VOICE_ID=
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_TTS_SPEED=1.13
MINIMAX_TTS_VOLUME=1
MINIMAX_TTS_PITCH=1
MINIMAX_TTS_EMOTION=happy
MINIMAX_TTS_ENABLE_VOICE_MODIFY=false
MINIMAX_TTS_MODIFY_PITCH=0
MINIMAX_TTS_INTENSITY=0
MINIMAX_TTS_TIMBRE=0

# 可选: 黑客松现场公网/内网演示地址, 用于分享二维码
# 不填则自动使用本机局域网 IP, 例如 http://172.20.10.2:3000
NEXT_PUBLIC_DEMO_URL=
